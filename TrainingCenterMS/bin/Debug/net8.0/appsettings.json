{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=Alaa\\SQLEXPRESS;Database=TrainingCenterDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Email": "alaaageez1999@gmail.com",
    "Password": "ksie crsn lqck hinm"
  },

  "JwtSettings": {
    "SecretKey": "THIS_IS_A_VERY_SECRET_KEY_123456",
    "Issuer": "StudentApi",
    "Audience": "StudentApiUsers",
    "AccessTokenExpiryMinutes": 30,
    "RefreshTokenExpiryDays": 7
  },

  "OtpSettings": {
    "ExpiryMinutes": 15
  },

  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      // ==========================================
      // 1.(Critical Auth & Anti-Brute Force)
      // ==========================================
      {
        "Endpoint": "POST:/api/auth/login",
        "Period": "15m",
        "Limit": 5,
        "QuotaExceededMessage": "Too many login attempts. Please try again after 15 minutes."
      },
      {
        "Endpoint": "POST:/api/auth/forgot-password",
        "Period": "15m",
        "Limit": 3,
        "QuotaExceededMessage": "Too many reset attempts. Please try again after 15 minutes."
      },
      {
        "Endpoint": "POST:/api/auth/verify-email",
        "Period": "15m",
        "Limit": 5,
        "QuotaExceededMessage": "Too many verification attempts. Please try again after 15 minutes."
      },
      {
        "Endpoint": "POST:/api/auth/resend-verification-email",
        "Period": "15m",
        "Limit": 5,
        "QuotaExceededMessage": "Too many email requests. Please try again after 15 minutes."
      },
      {
        "Endpoint": "POST:/api/auth/register/student",
        "Period": "1m",
        "Limit": 5,
        "QuotaExceededMessage": "Registration limit exceeded. Please wait a minute."
      },
      {
        "Endpoint": "GET:/api/countries/search",
        "Period": "1m",
        "Limit": 15,
        "QuotaExceededMessage": "Too many search requests. Please slow down."
      },

      // ==========================================
      // 2. (Standard Writes / Sensitive User Ops)
      // ==========================================
      {
        "Endpoint": "POST:/api/enrollments",
        "Period": "1m",
        "Limit": 10,
        "QuotaExceededMessage": "Too many enrollment actions. Please slow down."
      },
      {
        "Endpoint": "DELETE:/api/enrollments/*",
        "Period": "1m",
        "Limit": 10,
        "QuotaExceededMessage": "Too many cancel enrollment actions."
      },
      {
        "Endpoint": "PATCH:/api/users/change-email",
        "Period": "1m",
        "Limit": 3,
        "QuotaExceededMessage": "Email change attempts limited. Try again later."
      },
      {
        "Endpoint": "PUT:/api/users/change-password/*",
        "Period": "1m",
        "Limit": 5,
        "QuotaExceededMessage": "Password change attempts limited."
      },
      {
        "Endpoint": "POST:/api/people",
        "Period": "1m",
        "Limit": 10,
        "QuotaExceededMessage": "Profile setup limited."
      },
      {
        "Endpoint": "PUT:/api/people/me",
        "Period": "1m",
        "Limit": 20,
        "QuotaExceededMessage": "Profile update limited."
      },
      {
        "Endpoint": "PUT:/api/students/*",
        "Period": "1m",
        "Limit": 20,
        "QuotaExceededMessage": "Student profile update limited."
      },

      // ==========================================
      // 3. (Public Read Operations)
      // ==========================================
      {
        "Endpoint": "GET:/api/courses/all-courses",
        "Period": "1m",
        "Limit": 100,
        "QuotaExceededMessage": "Too many requests on course directory."
      },
      {
        "Endpoint": "GET:/api/courses/*",
        "Period": "1m",
        "Limit": 120,
        "QuotaExceededMessage": "Rate limit exceeded for viewing courses."
      },
      {
        "Endpoint": "GET:/api/countries",
        "Period": "1m",
        "Limit": 100,
        "QuotaExceededMessage": "Rate limit exceeded for countries directory."
      },
      {
        "Endpoint": "GET:/api/countries/*",
        "Period": "1m",
        "Limit": 100,
        "QuotaExceededMessage": "Rate limit exceeded."
      },

      // ==========================================
      // 4. Staff (Admin Controls)
      // ==========================================
      {
        "Endpoint": "GET:/api/students",
        "Period": "1m",
        "Limit": 200,
        "QuotaExceededMessage": "Admin limit exceeded."
      },
      {
        "Endpoint": "GET:/api/users/GetAll",
        "Period": "1m",
        "Limit": 200,
        "QuotaExceededMessage": "Admin limit exceeded."
      },
      {
        "Endpoint": "GET:/api/people/GetAll",
        "Period": "1m",
        "Limit": 200,
        "QuotaExceededMessage": "Admin limit exceeded."
      },
      {
        "Endpoint": "PATCH:/api/users/ChangeRole/*",
        "Period": "1m",
        "Limit": 50,
        "QuotaExceededMessage": "Admin role update limit exceeded."
      },

      // ==========================================
      // 5. (Catch-all Global Rule)
      // ==========================================
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60,
        "QuotaExceededMessage": "Too many requests. Please slow down."
      }
    ]
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  }
}